# ===========================================
# Authentication (NextAuth)
# ===========================================
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# AI / LLM
# ===========================================
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ===========================================
# Search
# ===========================================
SERP_API_KEY=your-serpapi-key

# ===========================================
# Analytics (optional)
# ===========================================
NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id

# ===========================================
# Agent API (for Scout / external agents)
# ===========================================
AGENT_API_KEY=generate-a-long-random-secret-here
AGENT_EMAIL=agent@example.com

# ===========================================
# Email (SMTP)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=UseStack <notifications@example.com>
NOTIFICATION_EMAIL_TO=team@example.com
REPORT_EMAIL_TO=team@example.com
